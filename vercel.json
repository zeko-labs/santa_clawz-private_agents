{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.santaclawz.ai/api/:path*"
    },
    {
      "source": "/.well-known/:path*",
      "destination": "https://api.santaclawz.ai/.well-known/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
