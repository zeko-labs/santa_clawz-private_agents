ZEKO_GRAPHQL=https://testnet.zeko.io/graphql
ZEKO_ARCHIVE=https://archive.testnet.zeko.io/graphql
ZEKO_NETWORK_ID=testnet
TX_FEE=200000000

# Zeko mainnet social anchor deployment. Mainnet deploy scripts also require
# ZEKO_CONFIRM_MAINNET=true or --confirm-mainnet.
# ZEKO_GRAPHQL=https://mainnet.zeko.io/graphql
# ZEKO_ARCHIVE=https://archive.mainnet.zeko.io/graphql
# ZEKO_NETWORK_ID=zeko:zeko-mainnet
# ZEKO_CONFIRM_MAINNET=true

# Or store the same secret in macOS Keychain service ZekoAI_SUBMITTER_PRIVATE_KEY
DEPLOYER_PRIVATE_KEY=
# Or store in Keychain service ClawZ_REGISTRY_PRIVATE_KEY
REGISTRY_PRIVATE_KEY=
# Or store in Keychain service ClawZ_SESSION_PRIVATE_KEY
SESSION_PRIVATE_KEY=
# Or store in Keychain service ClawZ_TURN_PRIVATE_KEY
TURN_PRIVATE_KEY=
# Or store in Keychain service ClawZ_APPROVAL_PRIVATE_KEY
APPROVAL_PRIVATE_KEY=
# Or store in Keychain service ClawZ_DISCLOSURE_PRIVATE_KEY
DISCLOSURE_PRIVATE_KEY=
# Or store in Keychain service ClawZ_ESCROW_PRIVATE_KEY
ESCROW_PRIVATE_KEY=
# Optional existing SocialAnchorKernel key. The standalone social-anchor deploy
# helper can also generate this key and write it to deployments/*.private.json.
SOCIAL_ANCHOR_PRIVATE_KEY=
